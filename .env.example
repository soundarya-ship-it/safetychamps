# RoadSoS Environment Variables
# Copy this file to .env and fill in your keys

# FREE Groq API key — get at https://console.groq.com
# Enables AI natural language understanding (Llama 3.1)
# Without this, the app still works using smart rule-based parsing
GROQ_API_KEY=gsk_your_key_here

# OPTIONAL: Google Maps API key for better number verification
# Free tier = $200/month credit (more than enough for hackathon)
# https://console.cloud.google.com → Maps → Places API
GOOGLE_MAPS_API_KEY=AIza_your_key_here

# Database path (default: roadsos.db in the project folder)
ROADSOS_DB=roadsos.db
